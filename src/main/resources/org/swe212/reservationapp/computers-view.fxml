<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.swe212.reservationapp.controller.ComputerController">
    <children>
        <Label layoutX="26.0" layoutY="20.0" text="ID:" />
        <TextField fx:id="idField" layoutX="89.0" layoutY="16.0" />
        <Button layoutX="267.0" layoutY="16.0" text="GET" onAction="#handleGet" prefWidth="60"/>
        <Button layoutX="267.0" layoutY="50.0" text="CLEAR" onAction="#handleClear" prefWidth="60"/>

        <Label layoutX="26.0" layoutY="50.0" text="BRAND:" />
        <TextField fx:id="brandField" layoutX="89.0" layoutY="46.0" />

        <Label layoutX="26.0" layoutY="79.0" text="MODEL:" />
        <TextField fx:id="modelField" layoutX="89.0" layoutY="76.0" />

        <Button layoutX="34.0" layoutY="139.0" text="SAVE" onAction="#handleSave" />
        <Button layoutX="96.0" layoutY="138.0" text="UPDATE" onAction="#handleUpdate" />
        <Button layoutX="178.0" layoutY="138.0" text="DELETE" onAction="#handleDelete" />
        <Button layoutX="259.0" layoutY="137.0" text="CLOSE" onAction="#handleClose" />
    </children>
</AnchorPane>